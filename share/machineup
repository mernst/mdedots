#!/bin/sh
# machineUp: redo commands in .xsession and myxloads that refer to the machine
#    With second argument, just display the commands, don't execute them.

if [ "$#" -gt 1 ]; then
  grep "$1" ~/.xsession
  myxloads --show 48 45 0 0 100 300 | grep "$1"
else
  grep "$1" ~/.xsession | sh -s
  myxloads --show 48 45 0 0 100 300 | grep "$1" | sh -s
fi
